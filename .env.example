# =============================================================================
# TradingAgents-CN 环境配置文件模板 v1.0.1
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env  (Windows: copy .env.example .env)
#   2. 运行生成安全凭据：python scripts/generate_credentials.py
#   3. 启动前验证：python scripts/validate_credentials.py
#   4. 确保所有 [REQUIRED] 项都已正确配置
#
# 分组说明：
#   [SECURITY]    安全凭据 — 必须使用 generate_credentials.py 生成
#   [REQUIRED]    必需配置 — 系统启动必需
#   [LLM]         LLM API 配置
#   [DATABASE]    数据库配置
#   [DATA_SOURCE] 数据源配置
#   [SYNC_TASK]   数据同步任务配置
#   [CACHE]       缓存配置
#   [DEPLOY]      部署 & 服务配置
#   [TRADINGAGENTS] TradingAgents 核心引擎配置
#   [HPC]         HPC-Loop / L-IWM / HSR-MC 配置
#   [AIF]         AIF 主动推理框架配置
#   [DIFFUSION]   扩散模块配置
#   [META]        分层生成模型 & 元学习器配置
#   [PROXY]       代理配置
#   [FRONTEND]    前端配置
#   [REDUNDANT]   冗余兼容配置
# =============================================================================


# =============================================================================
# [SECURITY] ⚠️ 安全凭据 — 必须使用 generate_credentials.py 生成
# =============================================================================
# 运行 python scripts/generate_credentials.py 自动生成以下凭据
# 生产环境必须修改！不要使用示例值！

# MongoDB root 密码（32 字符 Hex，自动生成）
MONGO_ROOT_PASSWORD=<CHANGE_ME>

# Redis 密码（32 字符 Hex，自动生成）
REDIS_PASSWORD=<CHANGE_ME>

# Cookie 加密密钥（128 字符 Hex，自动生成）
COOKIE_SECRET_KEY=<CHANGE_ME>

# JWT 签名密钥（64 字符 Hex，自动生成）
# 用于生成认证令牌，生产环境必须修改！
JWT_SECRET=<CHANGE_ME>

# CSRF 保护密钥（生产环境必须修改）
CSRF_SECRET=<CHANGE_ME>

# 初始管理员密码（24 字符可打印，自动生成）
ADMIN_PASSWORD=<CHANGE_ME>

# 🔒 [Bug B02] 管理员默认密码（用于 Web UI 的 streamlit auth_manager 创建默认用户）
# 必须设置！不设置则 auth_manager 无法创建默认用户
ADMIN_DEFAULT_PASSWORD=<CHANGE_ME>

# 🔒 [Bug B02] 普通用户默认密码（与 ADMIN_DEFAULT_PASSWORD 类似，用于创建普通用户）
USER_DEFAULT_PASSWORD=<CHANGE_ME>

# 配置加密密钥（用于加密存储敏感配置）（自动生成）
CONFIG_ENCRYPTION_KEY=<CHANGE_ME>


# =============================================================================
# [REQUIRED] 必需配置 — 系统启动必需的配置项
# =============================================================================

# --- 调试模式 ---
# 开发环境建议开启 true，生产环境设为 false
DEBUG=true

# --- 服务监听地址 ---
HOST=0.0.0.0
PORT=8000

# --- MongoDB 数据库配置 ---
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=${MONGO_ROOT_PASSWORD}
MONGODB_DATABASE=tradingagentscn
MONGODB_AUTH_SOURCE=admin

# --- Redis 缓存配置 ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- 日志配置 ---
LOG_LEVEL=INFO
TRADINGAGENTS_LOG_LEVEL=INFO
TRADINGAGENTS_LOG_DIR=./logs

# --- 数据目录 ---
TRADINGAGENTS_DATA_DIR=./data
TRADINGAGENTS_RESULTS_DIR=./results
TRADINGAGENTS_CACHE_DIR=./dataflows/data_cache


# =============================================================================
# [LLM] LLM API 配置（至少配置一个）
# =============================================================================

# --- DeepSeek API（推荐，性价比高） ---
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ENABLED=false

# --- 阿里百炼 API（推荐，国产稳定） ---
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=
DASHSCOPE_ENABLED=false

# --- OpenAI API ---
OPENAI_API_KEY=
OPENAI_ENABLED=false

# --- Google AI API ---
GOOGLE_API_KEY=
GOOGLE_ENABLED=false

# --- Anthropic API ---
ANTHROPIC_API_KEY=

# --- 百度千帆 API ---
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_ENABLED=false

# --- 智谱 AI API ---
ZHIPU_API_KEY=
ZHIPU_BASE_URL=

# --- OpenRouter API ---
OPENROUTER_API_KEY=
OPENROUTER_ENABLED=false

# --- AIHubMix API ---
AIHUBMIX_API_KEY=
AIHUBMIX_ENABLED=false

# --- SiliconFlow API ---
SILICONFLOW_API_KEY=

# --- 自定义 OpenAI 兼容 API ---
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=

# --- 千帆 API ---
QIANFAN_API_KEY=

# --- LLM 提供商选择 ---
# 可选：deepseek / dashscope / openai / google / anthropic / custom_openai / openrouter / glm / siliconflow / aihubmix
TRADINGAGENTS_LLM_PROVIDER=dashscope
TRADINGAGENTS_DEEP_THINK_LLM=qwen-plus-latest
TRADINGAGENTS_QUICK_THINK_LLM=qwen-turbo-latest
TRADINGAGENTS_LLM_BACKEND_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TRADINGAGENTS_SAMPLING_TEMPERATURE=0.1
TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese

# --- 在线工具开关 ---
ONLINE_TOOLS_ENABLED=false
ONLINE_NEWS_ENABLED=true
REALTIME_DATA_ENABLED=false


# =============================================================================
# [DATABASE] 数据库高级配置
# =============================================================================

# --- MongoDB 扩展配置 ---
MONGODB_CONNECTION_STRING=mongodb://admin:${MONGO_ROOT_PASSWORD}@localhost:27017/tradingagentscn?authSource=admin
MONGODB_URL=mongodb://admin:${MONGO_ROOT_PASSWORD}@localhost:27017/tradingagentscn?authSource=admin
MONGODB_DATABASE_NAME=tradingagentscn
MONGODB_DATABASE_SCOPE=auto
# 可选：explicit / major / major_instance / auto
MONGODB_DATABASE_INSTANCE=
ALLOW_SHARED_DB_IN_DEBUG=false
MONGODB_ENABLED=false
MONGO_MAX_CONNECTIONS=100
MONGO_MIN_CONNECTIONS=10
MONGO_CONNECT_TIMEOUT_MS=30000
MONGO_SOCKET_TIMEOUT_MS=60000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# --- Redis 扩展配置 ---
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0
REDIS_ENABLED=false
REDIS_MAX_CONNECTIONS=20
REDIS_RETRY_ON_TIMEOUT=true
REDIS_DATABASE=0

# --- 存储配置 ---
USE_MONGODB_STORAGE=true
MEMORY_ENABLED=false


# =============================================================================
# [DATA_SOURCE] 数据源配置（至少配置一个）
# =============================================================================

# --- Tushare（专业A股数据，需注册） ---
# 注册地址：https://tushare.pro/
TUSHARE_TOKEN=
TUSHARE_ENABLED=false
TUSHARE_TIER=standard
TUSHARE_RATE_LIMIT_SAFETY_MARGIN=0.8

# --- AKShare（无需注册，推荐作为默认数据源） ---
AKSHARE_ENABLED=true

# --- BaoStock ---
BAOSTOCK_ENABLED=true

# --- FinnHub（美股数据） ---
FINNHUB_API_KEY=
FINNHUB_ENABLED=false

# --- Alpha Vantage ---
ALPHA_VANTAGE_API_KEY=

# --- NewsAPI ---
NEWSAPI_KEY=

# --- 默认数据源选择 ---
# A股：akshare / tushare / baostock
DEFAULT_CHINA_DATA_SOURCE=akshare
# 美股：yfinance / finnhub
DEFAULT_US_DATA_SOURCE=yfinance

# --- Reddit（用于市场情绪分析，可选） ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# --- 外部行情数据服务 ---
STOCK_DATA_API_URL=
STOCK_DATA_API_KEY=


# =============================================================================
# [SYNC_TASK] 数据同步任务配置
# =============================================================================

# --- Tushare 数据同步 ---
TUSHARE_UNIFIED_ENABLED=false
TUSHARE_BASIC_INFO_SYNC_ENABLED=true
TUSHARE_BASIC_INFO_SYNC_CRON=0 2 * * *
TUSHARE_QUOTES_SYNC_ENABLED=true
TUSHARE_QUOTES_SYNC_CRON=*/5 9-15 * * 1-5
TUSHARE_HISTORICAL_SYNC_ENABLED=true
TUSHARE_HISTORICAL_SYNC_CRON=0 16 * * 1-5
TUSHARE_FINANCIAL_SYNC_ENABLED=true
TUSHARE_FINANCIAL_SYNC_CRON=0 3 * * 0
TUSHARE_STATUS_CHECK_ENABLED=true
TUSHARE_STATUS_CHECK_CRON=0 * * * *
TUSHARE_INIT_HISTORICAL_DAYS=365
TUSHARE_INIT_BATCH_SIZE=100
TUSHARE_INIT_AUTO_START=false

# --- AKShare 数据同步 ---
AKSHARE_UNIFIED_ENABLED=true
AKSHARE_BASIC_INFO_SYNC_ENABLED=true
AKSHARE_BASIC_INFO_SYNC_CRON=0 3 * * *
AKSHARE_QUOTES_SYNC_ENABLED=true
AKSHARE_QUOTES_SYNC_CRON=*/30 9-15 * * 1-5
AKSHARE_HISTORICAL_SYNC_ENABLED=true
AKSHARE_HISTORICAL_SYNC_CRON=0 17 * * 1-5
AKSHARE_FINANCIAL_SYNC_ENABLED=true
AKSHARE_FINANCIAL_SYNC_CRON=0 4 * * 0
AKSHARE_STATUS_CHECK_ENABLED=true
AKSHARE_STATUS_CHECK_CRON=30 * * * *
AKSHARE_INIT_HISTORICAL_DAYS=365
AKSHARE_INIT_BATCH_SIZE=100
AKSHARE_INIT_AUTO_START=false

# --- BaoStock 数据同步 ---
BAOSTOCK_UNIFIED_ENABLED=true
BAOSTOCK_BASIC_INFO_SYNC_ENABLED=true
BAOSTOCK_BASIC_INFO_SYNC_CRON=0 4 * * *
BAOSTOCK_DAILY_QUOTES_SYNC_ENABLED=true
BAOSTOCK_DAILY_QUOTES_SYNC_CRON=0 16 * * 1-5
BAOSTOCK_HISTORICAL_SYNC_ENABLED=true
BAOSTOCK_HISTORICAL_SYNC_CRON=0 18 * * 1-5
BAOSTOCK_STATUS_CHECK_ENABLED=true
BAOSTOCK_STATUS_CHECK_CRON=45 * * * *
BAOSTOCK_INIT_HISTORICAL_DAYS=365
BAOSTOCK_INIT_BATCH_SIZE=50
BAOSTOCK_INIT_AUTO_START=false

# --- 基础信息同步 ---
SYNC_STOCK_BASICS_ENABLED=true
SYNC_STOCK_BASICS_CRON=
SYNC_STOCK_BASICS_TIME=06:30

# --- 实时行情入库 ---
QUOTES_INGEST_ENABLED=false
QUOTES_INGEST_INTERVAL_SECONDS=360
QUOTES_BACKFILL_ON_STARTUP=true
QUOTES_BACKFILL_ON_OFFHOURS=true
QUOTES_ROTATION_ENABLED=true
QUOTES_TUSHARE_HOURLY_LIMIT=2
QUOTES_AUTO_DETECT_TUSHARE_PERMISSION=true

# --- 新闻数据同步 ---
NEWS_SYNC_ENABLED=true
NEWS_SYNC_CRON=0 */2 * * *
NEWS_SYNC_HOURS_BACK=24
NEWS_SYNC_MAX_PER_SOURCE=50


# =============================================================================
# [CACHE] 缓存配置
# =============================================================================

# 缓存策略：integrated（MongoDB+Redis，推荐）/ file（文件缓存）/ redis（仅Redis）
TA_CACHE_STRATEGY=integrated
TA_USE_APP_CACHE=true

# 缓存过期时间
CACHE_TTL=3600
SCREENING_CACHE_TTL=1800

# 内容缓存长度限制
MAX_CACHE_CONTENT_LENGTH=50000
ENABLE_CACHE_LENGTH_CHECK=false
MAX_EMBEDDING_CONTENT_LENGTH=50000
ENABLE_EMBEDDING_LENGTH_CHECK=true
FORCE_OPENAI_EMBEDDING=false

# 缓存清理
SKIP_CACHE_CLEAN=false


# =============================================================================
# [DEPLOY] 部署 & 服务配置
# =============================================================================

# --- Docker 环境标识 ---
DOCKER_CONTAINER=false

# --- CORS 配置 ---
# 🔒 [Bug B24] 生产环境禁止使用通配符 *（当 allow_credentials=True 时 FastAPI 会拒绝）
# 支持逗号分隔多个域名。示例:
#   CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
# 注意：ALLOWED_ORIGINS 和 CORS_ORIGINS 映射到同一个配置项（后者优先）
# BUG-146: 移除冗余 ALLOWED_HOSTS（与 CORS_ORIGINS 功能重叠），保留 CORS_ORIGINS 作为唯一 CORS 配置
ALLOWED_ORIGINS=http://localhost:3000
# ALLOWED_HOSTS=*  # 已弃用，功能与 CORS_ORIGINS 重叠
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# --- JWT 配置 ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- 安全配置 ---
BCRYPT_ROUNDS=12
SESSION_EXPIRE_HOURS=24

# --- 队列配置 ---
QUEUE_MAX_SIZE=10000
QUEUE_VISIBILITY_TIMEOUT=300
QUEUE_MAX_RETRIES=3
WORKER_HEARTBEAT_INTERVAL=30
QUEUE_POLL_INTERVAL_SECONDS=1.0
QUEUE_CLEANUP_INTERVAL_SECONDS=60.0

# --- 并发 & 速率限制 ---
DEFAULT_USER_CONCURRENT_LIMIT=3
GLOBAL_CONCURRENT_LIMIT=50
DEFAULT_DAILY_QUOTA=1000
RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100

# --- 文件上传 ---
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads

# --- SSE 配置 ---
SSE_POLL_TIMEOUT_SECONDS=1.0
SSE_HEARTBEAT_INTERVAL_SECONDS=10
SSE_TASK_MAX_IDLE_SECONDS=300
SSE_BATCH_POLL_INTERVAL_SECONDS=2.0
SSE_BATCH_MAX_IDLE_SECONDS=600

# --- 监控配置 ---
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=60

# --- 配置真相来源 ---
# file：以文件/env 为准（推荐，生产缺省）
# db：以数据库为准（仅兼容旧版）
# hybrid：文件/env 优先，DB 作为兜底
CONFIG_SOT=file

# --- 日志文件路径 ---
TRADINGAGENTS_LOG_FILE=./logs/tradingagents.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/tradingagents.log

# --- 日志配置 Profile ---
LOGGING_PROFILE=
# 可选：docker（使用 config/logging_docker.toml）


# =============================================================================
# [TRADINGAGENTS] TradingAgents 核心引擎配置
# =============================================================================

# --- 基础配置 ---
TRADINGAGENTS_VERSION=
TRADINGAGENTS_DB_USER=
TRADINGAGENTS_DB_HOST=

# --- LLM 配置覆盖 ---
TRADINGAGENTS_LLM_PROVIDER=dashscope
TRADINGAGENTS_DEEP_THINK_LLM=qwen-plus-latest
TRADINGAGENTS_QUICK_THINK_LLM=qwen-turbo-latest
TRADINGAGENTS_LLM_BACKEND_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 输出与显示 ---
TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese
TRADINGAGENTS_MAX_TOOL_ARGS_LENGTH=1000
TRADINGAGENTS_MAX_CONTENT_LENGTH=4000
TRADINGAGENTS_MAX_DISPLAY_MESSAGES=50
TRADINGAGENTS_REFRESH_RATE=5

# --- 辩论与讨论 ---
TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
TRADINGAGENTS_MAX_RISK_ROUNDS=1

# --- 检查点与基准 ---
TRADINGAGENTS_CHECKPOINT_ENABLED=false
TRADINGAGENTS_BENCHMARK_TICKER=

# --- DeepSeek 配置 ---
TRADINGAGENTS_DEEPSEEK_ENABLED=true
TRADINGAGENTS_DEEPSEEK_MODEL=deepseek-v4-flash
TRADINGAGENTS_DEEPSEEK_THINKING_MODE=enabled
TRADINGAGENTS_DEEPSEEK_THINKING_EFFORT=max
TRADINGAGENTS_DEEPSEEK_ADAPTER_TYPE=direct

# --- DashScope 配置 ---
TRADINGAGENTS_DASHSCOPE_ENABLED=true
TRADINGAGENTS_DASHSCOPE_MODEL=qwen-plus-latest

# --- 在线工具 ---
TRADINGAGENTS_ONLINE_TOOLS=false

# --- 采样温度 ---
TRADINGAGENTS_SAMPLING_TEMPERATURE=0.1

# --- 记忆日志 ---
TRADINGAGENTS_MEMORY_LOG_PATH=
TRADINGAGENTS_MEMORY_LOG_MAX_ENTRIES=

# --- 内存数据库 ---
TRADINGAGENTS_MONGODB_URI=
TRADINGAGENTS_DATABASE_NAME=tradingagents
TRADINGAGENTS_MONGODB_ENABLED=false

# --- 模型选择（覆盖） ---
TRADINGAGENTS_QUICK_MODEL=
TRADINGAGENTS_DEEP_MODEL=
TRADINGAGENTS_DEFAULT_MODEL=

# --- AIF 迭代 ---
TRADINGAGENTS_AIF_MAX_ITERATIONS=3

# --- Docker 内部 URL ---
TRADINGAGENTS_MONGODB_URL=mongodb://admin:${MONGO_ROOT_PASSWORD}@mongodb:27017/tradingagents?authSource=admin
TRADINGAGENTS_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
TRADINGAGENTS_CACHE_TYPE=redis


# =============================================================================
# [HPC] HPC-Loop / L-IWM / HSR-MC 高级分析引擎配置
# =============================================================================

# --- HPC-Loop 配置 ---
TRADINGAGENTS_HPC_LOOP_ENABLED=true
TRADINGAGENTS_HPC_PARALLEL_ANALYSTS=true
TRADINGAGENTS_HPC_GWS_ENABLED=true
TRADINGAGENTS_HPC_MEMORY_WINDOW_SIZE=100
TRADINGAGENTS_HPC_CAUSAL_MAX_HYPOTHESES=20
TRADINGAGENTS_HPC_PREDICTION_ERROR_THRESHOLD=2.0
TRADINGAGENTS_HPC_PREDICTION_ERROR_RATE=0.1

# --- L-IWM（学习型智能权重模型）配置 ---
TRADINGAGENTS_L_IWM_ENABLED=true

# --- HSR-MC（分层状态表征-蒙特卡洛）配置 ---
TRADINGAGENTS_HSRC_MC_ENABLED=true


# =============================================================================
# [AIF] AIF 主动推理框架配置
# =============================================================================

TRADINGAGENTS_USE_AIF_ENGINE=true
TRADINGAGENTS_AIF_LATENT_DIM=8
TRADINGAGENTS_AIF_N_SAMPLES=100
TRADINGAGENTS_AIF_LEARNING_RATE=0.01
TRADINGAGENTS_AIF_EFE_TEMPERATURE=1.0


# =============================================================================
# [DIFFUSION] 扩散模块配置
# =============================================================================

TRADINGAGENTS_DIFFUSION_ENABLED=true
TRADINGAGENTS_DIFFUSION_WEIGHT=0.3
TRADINGAGENTS_DIFFUSION_NUM_TIMESTEPS=50
TRADINGAGENTS_DIFFUSION_CSDI_ENABLED=false
TRADINGAGENTS_DIFFUSION_GENERATIVE_ENABLED=false


# =============================================================================
# [META] 分层生成模型 & 元学习器配置
# =============================================================================

TRADINGAGENTS_USE_HIERARCHICAL_MODEL=true
TRADINGAGENTS_META_CYCLE_INTERVAL=50
TRADINGAGENTS_META_WINDOW_SIZE=50
TRADINGAGENTS_META_LEARNING_RATE=0.001
TRADINGAGENTS_META_CUSUM_THRESHOLD=4.0


# =============================================================================
# [PROXY] 代理配置（国内数据源需绕过代理）
# =============================================================================

HTTP_PROXY=
HTTPS_PROXY=
# Windows 不支持通配符 *，必须使用完整域名
# 详细说明：docs/proxy_configuration.md
NO_PROXY=localhost,127.0.0.1,eastmoney.com,push2.eastmoney.com,82.push2.eastmoney.com,82.push2delay.eastmoney.com,gtimg.cn,sinaimg.cn,api.tushare.pro,baostock.com


# =============================================================================
# [FRONTEND] 前端配置
# =============================================================================

# 前端 API 基础地址（开发环境指向后端，生产通过 Nginx 代理）
VITE_API_BASE_URL=http://localhost:8000

# 后端 API 基础地址（Web 服务用）
WEBAPI_BASE_URL=http://localhost:8000

# 调试模式（前端显示调试信息）
DEBUG_MODE=true


# =============================================================================
# [REDUNDANT] 冗余兼容配置（为了向后兼容而保留）
# =============================================================================

# --- 旧版 API 别名（已弃用，但保留兼容） ---
# API_HOST=${HOST}
# API_PORT=${PORT}
# API_DEBUG=${DEBUG}

# --- 其他兼容性配置 ---
TIMEZONE=Asia/Shanghai
# BUG-144: 修复无效时区值（原值: "Asia/Summer_timezone：" 包含无效名称和全角冒号）
APP_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai

# --- 示例 SDK 同步服务配置 ---
EXAMPLE_SDK_BATCH_SIZE=100
EXAMPLE_SDK_RETRY_TIMES=3
EXAMPLE_SDK_RETRY_DELAY=5

# --- 香港市场数据配置 ---
HK_DATA_CACHE_HOURS=24
HK_DEFAULT_DATA_SOURCE=yfinance

# --- 美国市场数据配置 ---
US_DATA_CACHE_HOURS=24
US_DEFAULT_DATA_SOURCE=yfinance

# --- 分析师配置 ---
MARKET_ANALYST_LOOKBACK_DAYS=60

# --- MongoDB 迁移配置 ---
MONGO_SOURCE_DB=tradingagents
MONGO_TARGET_DB=tradingagentscn

# --- Docker 非标准端口 ---
# 当端口冲突时使用（Docker 环境默认使用 27018/6380）
# MONGODB_PORT=27018
# REDIS_PORT=6380
